  "issueTypes": {
    "template-literal-bug": {
      "severity": "critical",
      "description": "Template literal in className breaks Tailwind JIT compilation",
      "fix": "Use cn() utility or static class mapping"
    },
    "mode-radius-broken": {
      "severity": "critical",
      "description": "Mode radius token not applied correctly",
      "fix": "Replace template literal with mode helper function"
    },
    "malformed-classname": {
      "severity": "critical",
      "description": "Syntax error in className string",
      "fix": "Remove extra quotes or fix string concatenation"
    },
    "fragile-mode-check": {
      "severity": "high",
      "description": "Fragile string comparison on mode values",
      "fix": "Use proper mode helper or type-safe comparison"
    },
    "title-size-inconsistent": {
      "severity": "medium",
      "description": "Page title uses text-3xl instead of text-4xl",
      "fix": "Change text-3xl to text-4xl font-semibold tracking-tight"
    },
    "terminal-button-style": {
      "severity": "low",
      "description": "Uses > prefix on buttons (inconsistent with other pages)",
      "fix": "Either standardize to use > prefix everywhere or remove it"
    },
    "template-literal-conditional": {
      "severity": "low",
      "description": "Uses template literal for conditional classes instead of cn()",
      "fix": "Refactor to use cn() utility for conditional classes"
    },
    "text-transform-hardcoded": {
      "severity": "low",
      "description": "Has hardcoded uppercase instead of using text-transform token",
      "fix": "Use mode.textTransform or text-transform-button token"
    },
    "focus-ring-inconsistent": {
      "severity": "low",
      "description": "Focus ring width different from standard (2px)",
      "fix": "Standardize to ring-2 for all focusable elements"
    },
    "file-too-large": {
      "severity": "low",
      "description": "Component file is very large and could be split",
      "fix": "Consider splitting into multiple files for maintainability"
    },
    "unusual-grid-7col": {
      "severity": "info",
      "description": "Uses unusual 7-column grid layout",
      "fix": "Document if intentional or standardize to common grid patterns"
    }
  },

