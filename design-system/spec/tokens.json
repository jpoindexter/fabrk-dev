{
  "$schema": "https://design-tokens.org/schema",
  "version": "1.0.0",
  "name": "SaaS Design System",
  "description": "Token-driven, themeable design system for modern SaaS applications",

  "color": {
    "$description": "Semantic color tokens",

    "bg": {
      "base": { "$value": "{palette.gray.50}", "$type": "color", "$description": "Page background" },
      "surface": { "$value": "{palette.white}", "$type": "color", "$description": "Card/panel background" },
      "surface-raised": { "$value": "{palette.white}", "$type": "color", "$description": "Elevated surfaces (modals)" },
      "surface-sunken": { "$value": "{palette.gray.100}", "$type": "color", "$description": "Inset areas" },
      "surface-overlay": { "$value": "rgba(0, 0, 0, 0.5)", "$type": "color", "$description": "Backdrop overlays" },
      "muted": { "$value": "{palette.gray.100}", "$type": "color", "$description": "Subtle backgrounds" },
      "accent": { "$value": "{palette.primary.600}", "$type": "color", "$description": "Primary action backgrounds" },
      "accent-muted": { "$value": "{palette.primary.50}", "$type": "color", "$description": "Subtle accent backgrounds" },
      "accent-hover": { "$value": "{palette.primary.700}", "$type": "color", "$description": "Accent hover state" },
      "danger": { "$value": "{palette.red.600}", "$type": "color", "$description": "Destructive backgrounds" },
      "danger-muted": { "$value": "{palette.red.50}", "$type": "color", "$description": "Subtle danger backgrounds" },
      "success": { "$value": "{palette.green.600}", "$type": "color", "$description": "Success backgrounds" },
      "success-muted": { "$value": "{palette.green.50}", "$type": "color", "$description": "Subtle success backgrounds" },
      "warning": { "$value": "{palette.amber.500}", "$type": "color", "$description": "Warning backgrounds" },
      "warning-muted": { "$value": "{palette.amber.50}", "$type": "color", "$description": "Subtle warning backgrounds" },
      "info": { "$value": "{palette.blue.600}", "$type": "color", "$description": "Info backgrounds" },
      "info-muted": { "$value": "{palette.blue.50}", "$type": "color", "$description": "Subtle info backgrounds" }
    },

    "text": {
      "primary": { "$value": "{palette.gray.900}", "$type": "color", "$description": "Primary content" },
      "secondary": { "$value": "{palette.gray.700}", "$type": "color", "$description": "Secondary content" },
      "muted": { "$value": "{palette.gray.500}", "$type": "color", "$description": "Tertiary, placeholder" },
      "disabled": { "$value": "{palette.gray.400}", "$type": "color", "$description": "Disabled state" },
      "inverse": { "$value": "{palette.white}", "$type": "color", "$description": "Text on accent backgrounds" },
      "accent": { "$value": "{palette.primary.600}", "$type": "color", "$description": "Links, emphasis" },
      "accent-hover": { "$value": "{palette.primary.700}", "$type": "color", "$description": "Link hover" },
      "danger": { "$value": "{palette.red.600}", "$type": "color", "$description": "Error text" },
      "success": { "$value": "{palette.green.600}", "$type": "color", "$description": "Success text" },
      "warning": { "$value": "{palette.amber.600}", "$type": "color", "$description": "Warning text" },
      "info": { "$value": "{palette.blue.600}", "$type": "color", "$description": "Info text" }
    },

    "border": {
      "default": { "$value": "{palette.gray.200}", "$type": "color", "$description": "Standard borders" },
      "muted": { "$value": "{palette.gray.100}", "$type": "color", "$description": "Subtle borders" },
      "strong": { "$value": "{palette.gray.300}", "$type": "color", "$description": "Emphasized borders" },
      "accent": { "$value": "{palette.primary.600}", "$type": "color", "$description": "Accent borders" },
      "danger": { "$value": "{palette.red.500}", "$type": "color", "$description": "Error borders" },
      "success": { "$value": "{palette.green.500}", "$type": "color", "$description": "Success borders" },
      "focus": { "$value": "{palette.primary.500}", "$type": "color", "$description": "Focus rings" }
    }
  },

  "palette": {
    "$description": "Raw color palette values (do not use directly in components)",

    "white": { "$value": "#ffffff", "$type": "color" },
    "black": { "$value": "#000000", "$type": "color" },

    "gray": {
      "50": { "$value": "oklch(98% 0.005 240)", "$type": "color" },
      "100": { "$value": "oklch(96% 0.005 240)", "$type": "color" },
      "200": { "$value": "oklch(92% 0.005 240)", "$type": "color" },
      "300": { "$value": "oklch(87% 0.005 240)", "$type": "color" },
      "400": { "$value": "oklch(70% 0.005 240)", "$type": "color" },
      "500": { "$value": "oklch(55% 0.005 240)", "$type": "color" },
      "600": { "$value": "oklch(45% 0.005 240)", "$type": "color" },
      "700": { "$value": "oklch(37% 0.01 240)", "$type": "color" },
      "800": { "$value": "oklch(27% 0.01 240)", "$type": "color" },
      "900": { "$value": "oklch(21% 0.01 240)", "$type": "color" },
      "950": { "$value": "oklch(14% 0.01 240)", "$type": "color" }
    },

    "primary": {
      "50": { "$value": "oklch(97% 0.02 290)", "$type": "color" },
      "100": { "$value": "oklch(94% 0.04 290)", "$type": "color" },
      "200": { "$value": "oklch(88% 0.08 290)", "$type": "color" },
      "300": { "$value": "oklch(79% 0.14 290)", "$type": "color" },
      "400": { "$value": "oklch(70% 0.18 290)", "$type": "color" },
      "500": { "$value": "oklch(60% 0.20 290)", "$type": "color" },
      "600": { "$value": "oklch(52% 0.22 290)", "$type": "color" },
      "700": { "$value": "oklch(45% 0.22 290)", "$type": "color" },
      "800": { "$value": "oklch(38% 0.20 290)", "$type": "color" },
      "900": { "$value": "oklch(32% 0.18 290)", "$type": "color" },
      "950": { "$value": "oklch(22% 0.15 290)", "$type": "color" }
    },

    "red": {
      "50": { "$value": "oklch(97% 0.02 25)", "$type": "color" },
      "100": { "$value": "oklch(94% 0.05 25)", "$type": "color" },
      "200": { "$value": "oklch(88% 0.10 25)", "$type": "color" },
      "300": { "$value": "oklch(78% 0.16 25)", "$type": "color" },
      "400": { "$value": "oklch(68% 0.20 25)", "$type": "color" },
      "500": { "$value": "oklch(60% 0.22 25)", "$type": "color" },
      "600": { "$value": "oklch(52% 0.24 25)", "$type": "color" },
      "700": { "$value": "oklch(45% 0.22 25)", "$type": "color" },
      "800": { "$value": "oklch(38% 0.18 25)", "$type": "color" },
      "900": { "$value": "oklch(32% 0.14 25)", "$type": "color" },
      "950": { "$value": "oklch(22% 0.10 25)", "$type": "color" }
    },

    "green": {
      "50": { "$value": "oklch(97% 0.02 145)", "$type": "color" },
      "100": { "$value": "oklch(94% 0.04 145)", "$type": "color" },
      "200": { "$value": "oklch(88% 0.08 145)", "$type": "color" },
      "300": { "$value": "oklch(78% 0.12 145)", "$type": "color" },
      "400": { "$value": "oklch(70% 0.16 145)", "$type": "color" },
      "500": { "$value": "oklch(65% 0.18 145)", "$type": "color" },
      "600": { "$value": "oklch(55% 0.18 145)", "$type": "color" },
      "700": { "$value": "oklch(48% 0.16 145)", "$type": "color" },
      "800": { "$value": "oklch(40% 0.14 145)", "$type": "color" },
      "900": { "$value": "oklch(32% 0.12 145)", "$type": "color" },
      "950": { "$value": "oklch(22% 0.08 145)", "$type": "color" }
    },

    "amber": {
      "50": { "$value": "oklch(97% 0.02 85)", "$type": "color" },
      "100": { "$value": "oklch(94% 0.05 85)", "$type": "color" },
      "200": { "$value": "oklch(90% 0.10 85)", "$type": "color" },
      "300": { "$value": "oklch(85% 0.14 80)", "$type": "color" },
      "400": { "$value": "oklch(82% 0.16 75)", "$type": "color" },
      "500": { "$value": "oklch(80% 0.16 85)", "$type": "color" },
      "600": { "$value": "oklch(70% 0.18 75)", "$type": "color" },
      "700": { "$value": "oklch(60% 0.16 70)", "$type": "color" },
      "800": { "$value": "oklch(50% 0.14 65)", "$type": "color" },
      "900": { "$value": "oklch(40% 0.12 60)", "$type": "color" },
      "950": { "$value": "oklch(28% 0.08 55)", "$type": "color" }
    },

    "blue": {
      "50": { "$value": "oklch(97% 0.02 250)", "$type": "color" },
      "100": { "$value": "oklch(94% 0.04 250)", "$type": "color" },
      "200": { "$value": "oklch(88% 0.08 250)", "$type": "color" },
      "300": { "$value": "oklch(78% 0.14 250)", "$type": "color" },
      "400": { "$value": "oklch(68% 0.18 250)", "$type": "color" },
      "500": { "$value": "oklch(60% 0.18 250)", "$type": "color" },
      "600": { "$value": "oklch(52% 0.20 250)", "$type": "color" },
      "700": { "$value": "oklch(45% 0.18 250)", "$type": "color" },
      "800": { "$value": "oklch(38% 0.16 250)", "$type": "color" },
      "900": { "$value": "oklch(32% 0.14 250)", "$type": "color" },
      "950": { "$value": "oklch(22% 0.10 250)", "$type": "color" }
    }
  },

  "typography": {
    "$description": "Typography tokens",

    "family": {
      "sans": { "$value": "\"Inter\", system-ui, -apple-system, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "\"JetBrains Mono\", \"Fira Code\", ui-monospace, monospace", "$type": "fontFamily" },
      "display": { "$value": "\"Inter\", system-ui, sans-serif", "$type": "fontFamily" }
    },

    "size": {
      "2xs": { "$value": "0.625rem", "$type": "fontSize", "$description": "10px" },
      "xs": { "$value": "0.75rem", "$type": "fontSize", "$description": "12px" },
      "sm": { "$value": "0.875rem", "$type": "fontSize", "$description": "14px" },
      "base": { "$value": "1rem", "$type": "fontSize", "$description": "16px" },
      "lg": { "$value": "1.125rem", "$type": "fontSize", "$description": "18px" },
      "xl": { "$value": "1.25rem", "$type": "fontSize", "$description": "20px" },
      "2xl": { "$value": "1.5rem", "$type": "fontSize", "$description": "24px" },
      "3xl": { "$value": "1.875rem", "$type": "fontSize", "$description": "30px" },
      "4xl": { "$value": "2.25rem", "$type": "fontSize", "$description": "36px" },
      "5xl": { "$value": "3rem", "$type": "fontSize", "$description": "48px" },
      "6xl": { "$value": "3.75rem", "$type": "fontSize", "$description": "60px" },
      "7xl": { "$value": "4.5rem", "$type": "fontSize", "$description": "72px" },
      "8xl": { "$value": "6rem", "$type": "fontSize", "$description": "96px" }
    },

    "weight": {
      "normal": { "$value": "400", "$type": "fontWeight" },
      "medium": { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold": { "$value": "700", "$type": "fontWeight" }
    },

    "leading": {
      "none": { "$value": "1", "$type": "lineHeight" },
      "tight": { "$value": "1.25", "$type": "lineHeight" },
      "snug": { "$value": "1.375", "$type": "lineHeight" },
      "normal": { "$value": "1.5", "$type": "lineHeight" },
      "relaxed": { "$value": "1.625", "$type": "lineHeight" },
      "loose": { "$value": "2", "$type": "lineHeight" }
    },

    "tracking": {
      "tighter": { "$value": "-0.05em", "$type": "letterSpacing" },
      "tight": { "$value": "-0.025em", "$type": "letterSpacing" },
      "normal": { "$value": "0", "$type": "letterSpacing" },
      "wide": { "$value": "0.025em", "$type": "letterSpacing" },
      "wider": { "$value": "0.05em", "$type": "letterSpacing" },
      "widest": { "$value": "0.1em", "$type": "letterSpacing" }
    }
  },

  "space": {
    "$description": "Spacing scale based on 4px base unit",

    "0": { "$value": "0", "$type": "spacing" },
    "px": { "$value": "1px", "$type": "spacing" },
    "0.5": { "$value": "0.125rem", "$type": "spacing", "$description": "2px" },
    "1": { "$value": "0.25rem", "$type": "spacing", "$description": "4px" },
    "2": { "$value": "0.5rem", "$type": "spacing", "$description": "8px" },
    "3": { "$value": "0.75rem", "$type": "spacing", "$description": "12px" },
    "4": { "$value": "1rem", "$type": "spacing", "$description": "16px" },
    "5": { "$value": "1.25rem", "$type": "spacing", "$description": "20px" },
    "6": { "$value": "1.5rem", "$type": "spacing", "$description": "24px" },
    "8": { "$value": "2rem", "$type": "spacing", "$description": "32px" },
    "10": { "$value": "2.5rem", "$type": "spacing", "$description": "40px" },
    "12": { "$value": "3rem", "$type": "spacing", "$description": "48px" },
    "16": { "$value": "4rem", "$type": "spacing", "$description": "64px" },
    "20": { "$value": "5rem", "$type": "spacing", "$description": "80px" },
    "24": { "$value": "6rem", "$type": "spacing", "$description": "96px" },
    "32": { "$value": "8rem", "$type": "spacing", "$description": "128px" },
    "40": { "$value": "10rem", "$type": "spacing", "$description": "160px" },
    "48": { "$value": "12rem", "$type": "spacing", "$description": "192px" },
    "64": { "$value": "16rem", "$type": "spacing", "$description": "256px" },

    "component": {
      "padding": {
        "xs": { "$value": "{space.1}", "$type": "spacing" },
        "sm": { "$value": "{space.2}", "$type": "spacing" },
        "md": { "$value": "{space.4}", "$type": "spacing" },
        "lg": { "$value": "{space.6}", "$type": "spacing" },
        "xl": { "$value": "{space.8}", "$type": "spacing" }
      },
      "gap": {
        "xs": { "$value": "{space.1}", "$type": "spacing" },
        "sm": { "$value": "{space.2}", "$type": "spacing" },
        "md": { "$value": "{space.4}", "$type": "spacing" },
        "lg": { "$value": "{space.6}", "$type": "spacing" }
      }
    },

    "section": {
      "sm": { "$value": "{space.8}", "$type": "spacing" },
      "md": { "$value": "{space.12}", "$type": "spacing" },
      "lg": { "$value": "{space.16}", "$type": "spacing" },
      "xl": { "$value": "{space.24}", "$type": "spacing" }
    },

    "page": {
      "padding": { "$value": "{space.6}", "$type": "spacing" }
    }
  },

  "radius": {
    "$description": "Border radius scale",

    "none": { "$value": "0", "$type": "borderRadius" },
    "sm": { "$value": "0.125rem", "$type": "borderRadius", "$description": "2px" },
    "md": { "$value": "0.375rem", "$type": "borderRadius", "$description": "6px" },
    "lg": { "$value": "0.5rem", "$type": "borderRadius", "$description": "8px" },
    "xl": { "$value": "0.75rem", "$type": "borderRadius", "$description": "12px" },
    "2xl": { "$value": "1rem", "$type": "borderRadius", "$description": "16px" },
    "3xl": { "$value": "1.5rem", "$type": "borderRadius", "$description": "24px" },
    "full": { "$value": "9999px", "$type": "borderRadius" },

    "semantic": {
      "button": { "$value": "{radius.md}", "$type": "borderRadius" },
      "input": { "$value": "{radius.md}", "$type": "borderRadius" },
      "card": { "$value": "{radius.lg}", "$type": "borderRadius" },
      "modal": { "$value": "{radius.xl}", "$type": "borderRadius" },
      "badge": { "$value": "{radius.full}", "$type": "borderRadius" },
      "avatar": { "$value": "{radius.full}", "$type": "borderRadius" }
    }
  },

  "shadow": {
    "$description": "Shadow/elevation scale",

    "none": { "$value": "none", "$type": "boxShadow" },
    "xs": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)", "$type": "boxShadow" },
    "sm": { "$value": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)", "$type": "boxShadow" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)", "$type": "boxShadow" },
    "lg": { "$value": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)", "$type": "boxShadow" },
    "xl": { "$value": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)", "$type": "boxShadow" },
    "2xl": { "$value": "0 25px 50px -12px rgb(0 0 0 / 0.25)", "$type": "boxShadow" },
    "inner": { "$value": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)", "$type": "boxShadow" }
  },

  "motion": {
    "$description": "Animation and transition tokens",

    "duration": {
      "instant": { "$value": "0ms", "$type": "duration" },
      "fast": { "$value": "100ms", "$type": "duration" },
      "normal": { "$value": "200ms", "$type": "duration" },
      "slow": { "$value": "300ms", "$type": "duration" },
      "slower": { "$value": "500ms", "$type": "duration" },
      "slowest": { "$value": "1000ms", "$type": "duration" }
    },

    "ease": {
      "linear": { "$value": "linear", "$type": "cubicBezier" },
      "in": { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "out": { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "in-out": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "bounce": { "$value": "cubic-bezier(0.68, -0.55, 0.265, 1.55)", "$type": "cubicBezier" },
      "spring": { "$value": "cubic-bezier(0.175, 0.885, 0.32, 1.275)", "$type": "cubicBezier" }
    },

    "transition": {
      "hover": { "$value": "{motion.duration.fast} {motion.ease.out}", "$type": "transition" },
      "active": { "$value": "{motion.duration.instant} {motion.ease.out}", "$type": "transition" },
      "enter": { "$value": "{motion.duration.normal} {motion.ease.out}", "$type": "transition" },
      "exit": { "$value": "{motion.duration.fast} {motion.ease.in}", "$type": "transition" },
      "expand": { "$value": "{motion.duration.slow} {motion.ease.in-out}", "$type": "transition" },
      "page": { "$value": "{motion.duration.slower} {motion.ease.in-out}", "$type": "transition" }
    }
  },

  "breakpoint": {
    "$description": "Responsive breakpoints (mobile-first)",

    "xs": { "$value": "0px", "$type": "dimension" },
    "sm": { "$value": "480px", "$type": "dimension" },
    "md": { "$value": "640px", "$type": "dimension" },
    "lg": { "$value": "768px", "$type": "dimension" },
    "xl": { "$value": "1024px", "$type": "dimension" },
    "2xl": { "$value": "1280px", "$type": "dimension" },
    "3xl": { "$value": "1536px", "$type": "dimension" }
  },

  "container": {
    "$description": "Container max-widths",

    "xs": { "$value": "320px", "$type": "dimension" },
    "sm": { "$value": "480px", "$type": "dimension" },
    "md": { "$value": "640px", "$type": "dimension" },
    "lg": { "$value": "768px", "$type": "dimension" },
    "xl": { "$value": "1024px", "$type": "dimension" },
    "2xl": { "$value": "1280px", "$type": "dimension" },
    "3xl": { "$value": "1536px", "$type": "dimension" },
    "full": { "$value": "100%", "$type": "dimension" },
    "prose": { "$value": "65ch", "$type": "dimension" }
  },

  "z-index": {
    "$description": "Z-index scale for layering",

    "behind": { "$value": "-1", "$type": "number" },
    "base": { "$value": "0", "$type": "number" },
    "raised": { "$value": "10", "$type": "number" },
    "dropdown": { "$value": "20", "$type": "number" },
    "sticky": { "$value": "30", "$type": "number" },
    "overlay": { "$value": "40", "$type": "number" },
    "modal": { "$value": "50", "$type": "number" },
    "popover": { "$value": "60", "$type": "number" },
    "toast": { "$value": "70", "$type": "number" },
    "tooltip": { "$value": "80", "$type": "number" },
    "max": { "$value": "9999", "$type": "number" }
  },

  "border": {
    "$description": "Border tokens",

    "width": {
      "none": { "$value": "0", "$type": "borderWidth" },
      "default": { "$value": "1px", "$type": "borderWidth" },
      "2": { "$value": "2px", "$type": "borderWidth" },
      "4": { "$value": "4px", "$type": "borderWidth" }
    }
  },

  "focus": {
    "$description": "Focus state tokens",

    "ring-width": { "$value": "2px", "$type": "borderWidth" },
    "ring-offset": { "$value": "2px", "$type": "spacing" },
    "ring-color": { "$value": "{color.border.focus}", "$type": "color" }
  },

  "accessibility": {
    "$description": "Accessibility-related tokens",

    "touch-target": {
      "min": { "$value": "44px", "$type": "dimension" },
      "comfortable": { "$value": "48px", "$type": "dimension" }
    }
  }
}
