# =============================================================================
# CRITICAL ENVIRONMENT VARIABLES
# =============================================================================
# These variables are VALIDATED at startup using Zod (src/lib/env.ts)
# Missing or invalid variables will FAIL LOUDLY with clear error messages
# in production to prevent silent failures.
#
# IMPORTANT: Required variables use requiredInProduction() - they're optional
# in development but required in production NODE_ENV. This allows you to
# build locally without setting up all services first.
#
# To skip validation entirely (e.g., for CI builds): SKIP_ENV_VALIDATION=true

# Database - REQUIRED IN PRODUCTION
DATABASE_URL="postgresql://user:password@localhost:5432/fabrk"
# Direct database connection (for Prisma migrations, optional)
DATABASE_URL_DIRECT=""

# Application URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"
NEXT_PUBLIC_SITE_DOMAIN="localhost:3000"  # Domain without protocol

# NextAuth - REQUIRED IN PRODUCTION (min 32 characters)
# Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Stripe Payment Processing - REQUIRED IF PAYMENTS ENABLED
# Get these from: https://dashboard.stripe.com/test/apikeys
# VALIDATION: Keys must start with sk_test_/sk_live_ (secret) and pk_test_/pk_live_ (publishable)
STRIPE_SECRET_KEY="sk_test_..."                      # Secret key (server-side only)
STRIPE_WEBHOOK_SECRET="whsec_..."                    # Webhook signing secret (from Webhooks section) - REQUIRED if STRIPE_SECRET_KEY is set
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."    # Publishable key (client-side safe)

# Stripe Pricing - CRITICAL: REQUIRED IN PRODUCTION IF STRIPE ENABLED
# IMPORTANT: Use Lookup Keys instead of price IDs
# Lookup keys allow price updates in Stripe dashboard without code changes
# Set in Stripe Dashboard: Products → Fabrk → Price → Lookup key field
# VALIDATION: Will fail loudly if not set in production or if using placeholder values
NEXT_PUBLIC_STRIPE_PRICE_FABRK="fabrk_purchase"  # One-time purchase: $299 (with $100 coupon = $199)

# Stripe Coupons/Promotion Codes (Optional)
# Promotion Code ID from Stripe Dashboard: Billing → Promotion codes
# Set this to enable the early adopter promotion code ($100 off for first 500 customers)
STRIPE_COUPON_EARLY_ADOPTER="promo_1SVGK4P7kSSEYWlXBq1LtaNM"  # Promotion Code ID for $100 off (EARLY500)

# GitHub Repository Access (for customer distribution)
# Automatically grant customers access to private boilerplate repo after purchase
# This enables the post-purchase workflow that adds buyers as collaborators
# Generate token at: https://github.com/settings/tokens (Personal access tokens → Tokens (classic))
# Required scopes: repo (full control), admin:repo_hook (for webhooks if needed)
# OPTIONAL: Only required if you want automatic GitHub repo access after purchase
GITHUB_ACCESS_TOKEN="ghp_your_personal_access_token_here"
GITHUB_REPO_OWNER="your-github-username-or-org"
GITHUB_REPO_NAME="fabrk-boilerplate"

# Email Service (Resend) - REQUIRED IF EMAIL FEATURES ENABLED
# VALIDATION: API key must start with re_
RESEND_API_KEY="re_..."
EMAIL_FROM="support@fabrek.dev"
EMAIL_REPLY_TO=""  # Optional reply-to address
CONTACT_FORM_EMAIL="support@fabrek.dev"  # Contact form submissions sent here
EMAIL_WORKER_INTERVAL="5000"  # Email queue polling interval in ms (default: 5000)

# Cron Jobs (for email worker)
CRON_SECRET="your-cron-secret-key-here"

# Pusher Real-Time (Optional)
# Get these from: https://dashboard.pusher.com/
# Free tier: 100 connections, 200k messages/day
# Used for real-time notifications, activity feeds, and presence tracking
PUSHER_APP_ID="your-app-id"
PUSHER_SECRET="your-secret-key"  # Server-side only
NEXT_PUBLIC_PUSHER_KEY="your-public-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"  # or eu, ap3, etc.

# Algolia Search (Optional)
# Get these from: https://www.algolia.com/dashboard
# Sign up for free tier: 10k requests/month, 1M records
# Used for command palette (⌘K) and site search
NEXT_PUBLIC_ALGOLIA_APP_ID="your-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY="your-search-only-api-key"
ALGOLIA_ADMIN_API_KEY="your-admin-api-key"  # Server-side only, for indexing

# Sanity CMS (Optional)
# Get these from: https://www.sanity.io/manage
# Free tier: unlimited API requests, 3 users
# Used for blog posts and documentation
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN="your-api-token"  # Server-side only, for write operations

# Product Download URLs (optional - defaults provided)
PRODUCT_DOWNLOAD_URL_DEV="https://example.com/download/dev"
PRODUCT_DOWNLOAD_URL_PRO="https://example.com/download/pro"
PRODUCT_DOWNLOAD_URL_ENT="https://example.com/download/ent"

# Sentry Error Tracking & Monitoring
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/your-project-id"
SENTRY_ORG="your-org-name"
SENTRY_PROJECT="fabrk"
SENTRY_AUTH_TOKEN="your-sentry-auth-token-here"

# Application Version (for Sentry releases)
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Redis Cache (Upstash) - REQUIRED FOR PRODUCTION
# Enables distributed rate limiting and caching across server instances
# Sign up at https://upstash.com/ (free tier: 10k requests/day)
# Without this, app will use in-memory LRU cache (resets on restart, single-instance only)
# See docs/02-guides/REDIS-SETUP.md for setup instructions
UPSTASH_REDIS_REST_URL="https://your-redis-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-rest-token-here"

# =============================================================================
# ENTERPRISE FEATURES (MFA, Teams, Jobs, Files, AI)
# =============================================================================

# File Storage (Cloud Upload)
# Auto-detects provider based on which env vars are set. Priority: R2 > S3 > Local
# Requires: npm install @aws-sdk/client-s3 @aws-sdk/s3-request-presigner

# Cloudflare R2 (preferred - no egress fees)
# Get credentials from: Cloudflare Dashboard → R2 → Manage R2 API tokens
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET="fabrk-uploads"
CLOUDFLARE_R2_ENDPOINT="https://[account-id].r2.cloudflarestorage.com"
CLOUDFLARE_R2_PUBLIC_URL=""  # Optional: Custom domain for public files

# AWS S3 (alternative)
# Get credentials from: AWS Console → IAM → Users → Security credentials
AWS_S3_ACCESS_KEY_ID=""
AWS_S3_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="fabrk-uploads"
AWS_S3_REGION="us-east-1"

# =============================================================================
# AI SERVICES
# =============================================================================
# Priority: OpenAI > Google > Ollama (cloud providers have better structured output support)
# Ollama is used as fallback when no cloud API keys are configured

# OpenAI API (Cloud) - RECOMMENDED for structured outputs
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Google AI API (Gemini) - Good alternative for structured outputs
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=""

# Anthropic API (Claude) - For future use
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Ollama (Local AI - Fallback when no cloud keys are set)
# Install: https://ollama.ai/download
# Run: ollama serve && ollama pull llama3.1:8b
# Note: Ollama uses text parsing instead of structured outputs
OLLAMA_ENABLED="true"  # Set to "true" to enable Ollama fallback
OLLAMA_BASE_URL="http://localhost:11434/v1"  # Default Ollama API endpoint
OLLAMA_MODEL="llama3.1:8b"  # Model to use (run: ollama list)

# Background Jobs
# Worker settings for async job processing
JOB_WORKER_CONCURRENCY="5"  # Number of concurrent jobs
JOB_WORKER_INTERVAL="1000"  # Poll interval in ms

# PostHog Analytics
# Product analytics and feature flags
# Get these from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY="phc_..."  # Project API key
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"  # Or your self-hosted instance (https://app.posthog.com for EU)

# Google Analytics 4 (Optional)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""  # GA4 measurement ID (G-XXXXXXXXXX)

# Plausible Analytics (Optional)
# Privacy-friendly alternative to Google Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""  # Your domain for Plausible tracking

# Captcha Services (Optional - choose one)
# Used for spam protection on forms (contact, signup, etc.)
# hCaptcha - https://www.hcaptcha.com/
HCAPTCHA_SECRET_KEY=""

# reCAPTCHA - https://www.google.com/recaptcha/
RECAPTCHA_SECRET_KEY=""

# Cloudflare Turnstile - https://www.cloudflare.com/products/turnstile/
TURNSTILE_SECRET_KEY=""

# Polar.sh (Payment Processing & Product Sales)
# Get your access token from: https://polar.sh/settings
# Scopes needed: products:*, checkouts:*, customers:read, orders:read, files:*, webhooks:*
POLAR_ACCESS_TOKEN="polar_..."  # Organization access token
POLAR_WEBHOOK_SECRET=""  # Webhook signing secret (from webhook settings)
NEXT_PUBLIC_POLAR_PRODUCT_ID=""  # Your Fabrk product ID