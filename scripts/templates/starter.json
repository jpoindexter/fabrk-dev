{
  "name": "Starter",
  "description": "SQLite + Auth only. Perfect for demos and prototypes.",
  "setup_time": "30 seconds",
  "api_keys_needed": 0,
  "dependencies": [],
  "env": {
    "DATABASE_URL": "file:./dev.db",
    "NEXTAUTH_SECRET": "{{AUTO_GENERATE}}",
    "NEXTAUTH_URL": "http://localhost:3000",
    "NEXT_PUBLIC_APP_URL": "http://localhost:3000",
    "NODE_ENV": "development"
  },
  "features": {
    "database": "sqlite",
    "auth": true,
    "payments": null,
    "email": null,
    "analytics": null,
    "ai": null
  },
  "post_setup": [
    "npm run db:push",
    "npm run dev"
  ]
}
