{
  "$schema": "https://design-tokens.org/schema",
  "version": "2.0.0",
  "name": "Fabrk Design System",
  "description": "Token-driven, themeable design system for SaaS applications",
  "status": "FROZEN",
  "lastUpdated": "2025-12-06",

  "color": {
    "$description": "Semantic color tokens - resolved by active theme",

    "bg": {
      "base": { "$value": "{theme}", "$type": "color", "$description": "Page background" },
      "surface": { "$value": "{theme}", "$type": "color", "$description": "Card/panel background" },
      "surface-raised": {
        "$value": "{theme}",
        "$type": "color",
        "$description": "Elevated surfaces"
      },
      "surface-sunken": { "$value": "{theme}", "$type": "color", "$description": "Inset areas" },
      "muted": { "$value": "{theme}", "$type": "color", "$description": "Subtle backgrounds" },
      "accent": { "$value": "{theme}", "$type": "color", "$description": "Primary action" },
      "accent-muted": { "$value": "{theme}", "$type": "color", "$description": "Subtle accent" },
      "danger": { "$value": "{theme}", "$type": "color", "$description": "Destructive" },
      "danger-muted": { "$value": "{theme}", "$type": "color", "$description": "Subtle danger" },
      "success": { "$value": "{theme}", "$type": "color", "$description": "Success state" },
      "success-muted": { "$value": "{theme}", "$type": "color", "$description": "Subtle success" },
      "warning": { "$value": "{theme}", "$type": "color", "$description": "Warning state" },
      "warning-muted": { "$value": "{theme}", "$type": "color", "$description": "Subtle warning" },
      "info": { "$value": "{theme}", "$type": "color", "$description": "Info state" },
      "info-muted": { "$value": "{theme}", "$type": "color", "$description": "Subtle info" }
    },

    "text": {
      "primary": { "$value": "{theme}", "$type": "color", "$description": "Primary content" },
      "secondary": { "$value": "{theme}", "$type": "color", "$description": "Supporting content" },
      "muted": { "$value": "{theme}", "$type": "color", "$description": "Tertiary, placeholder" },
      "disabled": { "$value": "{theme}", "$type": "color", "$description": "Disabled state" },
      "inverse": { "$value": "{theme}", "$type": "color", "$description": "On accent backgrounds" },
      "accent": { "$value": "{theme}", "$type": "color", "$description": "Links, emphasis" },
      "danger": { "$value": "{theme}", "$type": "color", "$description": "Error text" },
      "success": { "$value": "{theme}", "$type": "color", "$description": "Success text" },
      "warning": { "$value": "{theme}", "$type": "color", "$description": "Warning text" },
      "info": { "$value": "{theme}", "$type": "color", "$description": "Info text" }
    },

    "border": {
      "default": { "$value": "{theme}", "$type": "color", "$description": "Standard borders" },
      "muted": { "$value": "{theme}", "$type": "color", "$description": "Subtle borders" },
      "strong": { "$value": "{theme}", "$type": "color", "$description": "Emphasized borders" },
      "accent": { "$value": "{theme}", "$type": "color", "$description": "Accent borders" },
      "danger": { "$value": "{theme}", "$type": "color", "$description": "Error borders" },
      "success": { "$value": "{theme}", "$type": "color", "$description": "Success borders" },
      "focus": { "$value": "{theme}", "$type": "color", "$description": "Focus rings" }
    }
  },

  "palette": {
    "$description": "Primitive color palettes - themes select from these",

    "gray": {
      "50": { "$value": "oklch(98% 0.005 240)", "$type": "color" },
      "100": { "$value": "oklch(96% 0.005 240)", "$type": "color" },
      "200": { "$value": "oklch(92% 0.005 240)", "$type": "color" },
      "300": { "$value": "oklch(87% 0.005 240)", "$type": "color" },
      "400": { "$value": "oklch(70% 0.005 240)", "$type": "color" },
      "500": { "$value": "oklch(55% 0.005 240)", "$type": "color" },
      "600": { "$value": "oklch(45% 0.005 240)", "$type": "color" },
      "700": { "$value": "oklch(37% 0.01 240)", "$type": "color" },
      "800": { "$value": "oklch(27% 0.01 240)", "$type": "color" },
      "900": { "$value": "oklch(21% 0.01 240)", "$type": "color" },
      "950": { "$value": "oklch(14% 0.01 240)", "$type": "color" }
