  "radius": {
    "$description": "Border radius scale",

    "none": { "$value": "0", "$type": "borderRadius" },
    "sm": { "$value": "0.125rem", "$type": "borderRadius", "$description": "2px" },
    "md": { "$value": "0.375rem", "$type": "borderRadius", "$description": "6px" },
    "lg": { "$value": "0.5rem", "$type": "borderRadius", "$description": "8px" },
    "xl": { "$value": "0.75rem", "$type": "borderRadius", "$description": "12px" },
    "2xl": { "$value": "1rem", "$type": "borderRadius", "$description": "16px" },
    "3xl": { "$value": "1.5rem", "$type": "borderRadius", "$description": "24px" },
    "full": { "$value": "9999px", "$type": "borderRadius" },

    "semantic": {
      "$description": "Component-specific radius - resolved by theme",
      "button": { "$value": "{theme}", "$type": "borderRadius" },
      "input": { "$value": "{theme}", "$type": "borderRadius" },
      "card": { "$value": "{theme}", "$type": "borderRadius" },
      "modal": { "$value": "{theme}", "$type": "borderRadius" },
      "badge": { "$value": "{theme}", "$type": "borderRadius" },
      "avatar": { "$value": "{theme}", "$type": "borderRadius" }
    }
  },

  "shadow": {
    "$description": "Shadow/elevation scale",

    "none": { "$value": "none", "$type": "boxShadow" },
    "xs": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)", "$type": "boxShadow" },
    "sm": {
      "$value": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
      "$type": "boxShadow"
    },
    "md": {
      "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
      "$type": "boxShadow"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
      "$type": "boxShadow"
    },
    "xl": {
      "$value": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
      "$type": "boxShadow"
    },
    "2xl": { "$value": "0 25px 50px -12px rgb(0 0 0 / 0.25)", "$type": "boxShadow" },
    "inner": { "$value": "inset 0 2px 4px 0 rgb(0 0 0 / 0.05)", "$type": "boxShadow" },

    "semantic": {
      "$description": "Component-specific shadows - resolved by theme",
      "card": { "$value": "{theme}", "$type": "boxShadow" },
      "dropdown": { "$value": "{theme}", "$type": "boxShadow" },
      "modal": { "$value": "{theme}", "$type": "boxShadow" },
      "button": { "$value": "{theme}", "$type": "boxShadow" }
    }
  },

