    "24": { "$value": "6rem", "$type": "spacing", "$description": "96px" },
    "32": { "$value": "8rem", "$type": "spacing", "$description": "128px" },

    "semantic": {
      "component-xs": { "$value": "{space.1}", "$type": "spacing" },
      "component-sm": { "$value": "{space.2}", "$type": "spacing" },
      "component-md": { "$value": "{space.4}", "$type": "spacing" },
      "component-lg": { "$value": "{space.6}", "$type": "spacing" },
      "component-xl": { "$value": "{space.8}", "$type": "spacing" },
      "gap-xs": { "$value": "{space.1}", "$type": "spacing" },
      "gap-sm": { "$value": "{space.2}", "$type": "spacing" },
      "gap-md": { "$value": "{space.4}", "$type": "spacing" },
      "gap-lg": { "$value": "{space.6}", "$type": "spacing" },
      "section-sm": { "$value": "{space.8}", "$type": "spacing" },
      "section-md": { "$value": "{space.12}", "$type": "spacing" },
      "section-lg": { "$value": "{space.16}", "$type": "spacing" },
      "section-xl": { "$value": "{space.24}", "$type": "spacing" },
      "page": { "$value": "{space.6}", "$type": "spacing" }
