      "tight": { "$value": "-0.025em", "$type": "letterSpacing" },
      "normal": { "$value": "0", "$type": "letterSpacing" },
      "wide": { "$value": "0.025em", "$type": "letterSpacing" },
      "wider": { "$value": "0.05em", "$type": "letterSpacing" },
      "widest": { "$value": "0.1em", "$type": "letterSpacing" }
