    "sm": { "$value": "480px", "$type": "dimension" },
    "md": { "$value": "640px", "$type": "dimension" },
    "lg": { "$value": "768px", "$type": "dimension" },
    "xl": { "$value": "1024px", "$type": "dimension" },
    "2xl": { "$value": "1280px", "$type": "dimension" },
    "3xl": { "$value": "1536px", "$type": "dimension" }
