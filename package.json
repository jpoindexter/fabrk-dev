{
  "name": "fabrk-boilerplate",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Next.js SaaS boilerplate",
  "scripts": {
    "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true && next dev",
    "dev:restart": "npm run dev",
    "build": "prisma generate && next build",
    "build:prod": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "npm run scan:hex && ESLINT_USE_FLAT_CONFIG=true eslint src",
    "lint:css": "stylelint \"src/**/*.css\" --allow-empty-input",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix --allow-empty-input",
    "lint:all": "npm run lint && npm run lint:css",
    "scan:hex": "node .internal/scripts/utilities/scan-stray-hex.mjs",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "db:migrate": "prisma migrate dev",
    "stripe:listen": "stripe listen --forward-to http://localhost:3000/api/webhooks/stripe",
    "jobs:worker": "node .internal/scripts/workers/job-worker.js",
    "jobs:dev": "nodemon .internal/scripts/workers/job-worker.js",
    "email:worker": "node .internal/scripts/workers/email-worker.js",
    "email:dev": "nodemon .internal/scripts/workers/email-worker.js",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "test:a11y": "playwright test tests/accessibility/components.a11y.spec.ts",
    "test:a11y:ui": "playwright test tests/accessibility/components.a11y.spec.ts --ui",
    "test:a11y:headed": "playwright test tests/accessibility/components.a11y.spec.ts --headed",
    "test:a11y:report": "npm run test:a11y && open tests/accessibility/reports/",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "test:visual:report": "playwright show-report",
    "analyze": "ANALYZE=true npm run build",
    "docs:api": "typedoc",
    "docs:serve": "serve docs/api",
    "lighthouse": "./.internal/scripts/lighthouse-audit.sh",
    "lighthouse:ci": "lhci autorun",
    "audit:staged": "node .internal/scripts/utilities/pre-commit-audit.mjs",
    "audit:design": "node .internal/scripts/utilities/design-system-audit.mjs",
    "audit:design:json": "node .internal/scripts/utilities/design-system-audit.mjs --json",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.tsx": [
      "node .internal/scripts/utilities/pre-commit-audit.mjs"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^2.0.44",
    "@ai-sdk/openai": "^2.0.79",
    "@ai-sdk/openai-compatible": "^1.0.28",
    "@auth/prisma-adapter": "^2.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@lemonsqueezy/lemonsqueezy.js": "^4.0.0",
    "@octokit/rest": "^22.0.1",
    "@polar-sh/sdk": "^0.41.5",
    "@portabletext/react": "^5.0.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.1.15",
