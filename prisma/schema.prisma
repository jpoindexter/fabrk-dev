// Simplified Prisma Schema - ShipFast Style
// Only essential models for SaaS boilerplate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// AUTHENTICATION (NextAuth)
// ===========================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  password      String?   // For credentials auth
  role          Role      @default(USER)
  
  // Stripe integration
  customerId       String?   @unique // Stripe customer ID
  tier             String    @default("free") // free, starter, pro
  subscriptionTier String?   // Subscription tier (for NextAuth session)
  trialEndsAt      DateTime? // Trial expiration date
  licenseKey       String?   @unique // Product license key

  // Simple security
  resetToken    String?   @unique
  resetExpires  DateTime?
  verifyToken   String?   @unique
  sessionVersion Int      @default(1) // Incremented to invalidate all sessions

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  payments           Payment[]
  mfaDevices         MFADevice[]
  backupCodes        BackupCode[]
  organizations      OrganizationMember[]
  organizationInvites OrganizationInvite[]
  uploads            Upload[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// ===========================
// PAYMENTS (Stripe)
// ===========================

model Payment {
  id               String   @id @default(cuid())
  userId           String
  stripeId         String   @unique // payment_intent or session id
  stripePaymentId  String?  // Stripe payment_intent ID (for compatibility)
  amount           Int      // cents
  status           String   // succeeded, failed, pending
  productId        String?  // Your product identifier
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeId])
}

// Prevent duplicate checkouts on refresh
model CheckoutSession {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String   @unique // Stripe checkout session ID
  priceId    String
  createdAt  DateTime @default(now())
  expiresAt  DateTime // 24 hours

  @@index([userId])
  @@index([sessionId])
}

// Prevent duplicate webhook processing
model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique // Stripe event ID
  processed DateTime @default(now())

  @@index([eventId])
}

// ===========================
// MULTI-FACTOR AUTHENTICATION
// ===========================

model MFADevice {
  id        String    @id @default(cuid())
  userId    String
  type      String    @default("totp") // totp, sms, webauthn
  secret    String?   // TOTP secret
  verified  Boolean   @default(false)
  name      String?   // Device name
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  code      String    // Hashed backup code
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

// ===========================
// TEAMS/ORGANIZATIONS
// ===========================

model Organization {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  logo           String?
  plan           String   @default("FREE") // FREE, STARTER, PRO, ENTERPRISE
  customerId     String?  @unique // Stripe customer ID
  subscriptionId String?  // Stripe subscription ID
  settings       Json?    // Organization settings
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  members  OrganizationMember[]
  invites  OrganizationInvite[]
  uploads  Upload[]

  @@index([slug])
}

model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole  @default(MEMBER)
  joinedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationInvite {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           OrgRole   @default(MEMBER)
  invitedBy      String
  token          String    @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

// ===========================
// FILE UPLOADS
// ===========================

model Upload {
  id             String   @id @default(cuid())
  userId         String
  organizationId String?
  filename       String
  originalName   String
  mimeType       String
  size           Int      // bytes
  url            String
  key            String   // S3 key
  bucket         String?
  metadata       Json?
  visibility     String   @default("private") // private, public
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

// ===========================
// BACKGROUND JOBS
// ===========================

model Job {
  id           String    @id @default(cuid())
  type         String    // email, webhook, report, etc.
  status       JobStatus @default(PENDING)
  priority     Int       @default(0) // Higher = more priority
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  data         Json?     // Job payload
  result       Json?     // Job result
  error        String?   // Error message
  scheduledFor DateTime? // For delayed jobs
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([scheduledFor])
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}
