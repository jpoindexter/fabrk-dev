// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// AUTHENTICATION MODELS
// ===========================

// User model for authentication
model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  name               String?
  image              String?
  emailVerified      DateTime?
  password           String?   // For email/password auth
  role               Role      @default(USER)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Personal subscription (for backwards compatibility)
  subscriptionTier   String    @default("trial") // trial, starter, professional, enterprise
  tier               String    @default("trial") // Current user tier (trial, complete)
  customerId         String?   // Stripe customer ID
  trialEndsAt        DateTime? // For trial periods
  licenseKey         String?   // License key for purchased products
  accessGrantedAt    DateTime? // When access was granted

  // Usage tracking
  userCount          Int       @default(1) // Track usage for limits
  apiCalls           Int       @default(0) // Track API usage
  storageUsed        Int       @default(0) // Track storage in MB
  projectCount       Int       @default(1) // Track number of projects

  // Security
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  emailVerifyToken    String?   @unique
  lastPasswordChange  DateTime?
  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?

  // Relations
  accounts           Account[]
  sessions           Session[]
  payments           Payment[]
  subscription       Subscription?

  @@index([email])
  @@index([passwordResetToken])
}

// OAuth accounts
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Sessions for auth
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Verification tokens for passwordless auth
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User roles
enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// ===========================
// PAYMENT & SUBSCRIPTION MODELS
// ===========================

// Stripe payments
model Payment {
  id                String   @id @default(cuid())
  userId            String
  stripePaymentId   String   @unique
  stripeCustomerId  String
  amount            Int      // Amount in cents
  currency          String   @default("usd")
  status            PaymentStatus
  description       String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
}

// Subscriptions
model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  stripeSubscriptionId String   @unique
  stripeCustomerId     String
  stripePriceId        String
  status              SubscriptionStatus
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  PAST_DUE
  TRIALING
  UNPAID
}

// ===========================
// ONE-TIME PAYMENT MODELS
// ===========================

// Customer record for one-time purchases
model Customer {
  id              String     @id @default(cuid())
  email           String     @unique
  name            String
  totalPurchases  Int        @default(0)
  totalSpent      Int        @default(0) // in cents
  lastPurchaseAt  DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  purchases       Purchase[]

  @@index([email])
}

// Purchase record from Gumroad or Stripe
model Purchase {
  id                String     @id @default(cuid())
  email             String
  name              String
  licenseKey        String     @unique

  // Payment provider fields (one will be set)
  provider          PaymentProvider @default(GUMROAD)
  gumroadSaleId     String?    @unique // For Gumroad
  stripeCustomerId  String?    // For Stripe
  stripeSessionId   String?    @unique // For Stripe
  stripePaymentId   String?    // For Stripe

  amount            Int        // in cents
  productId         String?
  tier              String?    // 'developer' | 'professional' | 'enterprise'
  status            PurchaseStatus @default(ACTIVE)
  downloadCount     Int        @default(0)
  lastDownloadAt    DateTime?
  welcomeEmailSent  Boolean    @default(false)
  purchasedAt       DateTime
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  customer          Customer   @relation(fields: [email], references: [email])
  downloadLogs      DownloadLog[]

  @@index([licenseKey])
  @@index([email])
  @@index([gumroadSaleId])
  @@index([stripeSessionId])
}

// Download log for tracking and rate limiting
model DownloadLog {
  id              String     @id @default(cuid())
  purchaseId      String
  ipAddress       String
  userAgent       String
  version         String
  createdAt       DateTime   @default(now())

  purchase        Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([createdAt])
}

// Email queue for retry logic
model EmailQueue {
  id              String     @id @default(cuid())
  purchaseId      String
  type            EmailType
  to              String
  subject         String?
  status          EmailStatus @default(PENDING)
  retryCount      Int        @default(0)
  lastError       String?
  sentAt          DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum PurchaseStatus {
  ACTIVE
  REVOKED
  REFUNDED
}

enum EmailType {
  WELCOME
  UPDATE
  SUPPORT
}

enum EmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

enum PaymentProvider {
  GUMROAD
  STRIPE
}

// ===========================
// STRIPE WEBHOOK & IDEMPOTENCY
// ===========================

// Idempotency tracking for checkout sessions
model CheckoutIdempotency {
  id              String   @id @default(cuid())
  idempotencyKey  String   @unique
  userId          String?  // Null for guest checkouts
  sessionId       String   // Stripe checkout session ID
  priceId         String
  createdAt       DateTime @default(now())
  expiresAt       DateTime // Expire after 24 hours

  @@index([idempotencyKey])
  @@index([userId])
  @@index([createdAt])
}

// Webhook event tracking for idempotency
model WebhookEvent {
  id              String   @id @default(cuid())
  eventId         String   @unique // Stripe event ID
  eventType       String   // Event type (checkout.session.completed, etc.)
  processedAt     DateTime @default(now())
  payload         Json?    // Store event payload for debugging

  @@index([eventId])
  @@index([eventType])
  @@index([processedAt])
}
