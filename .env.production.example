# =============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# =============================================================================
# Copy to .env.production.local and fill in your production values
# These are STRICTLY VALIDATED at startup - missing values will fail loudly
#
# SECURITY: Never commit this file with real values!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED - Application will not start without these
# -----------------------------------------------------------------------------

# Database (PostgreSQL)
# Use connection pooler for production (e.g., Prisma Data Proxy, PgBouncer)
DATABASE_URL="postgresql://user:password@your-db-host:5432/fabrk?sslmode=require"

# Application URLs (use your production domain)
NEXT_PUBLIC_APP_URL="https://fabrk.dev"
NEXT_PUBLIC_API_URL="https://fabrk.dev/api"
NEXT_PUBLIC_SITE_DOMAIN="fabrk.dev"

# NextAuth (CRITICAL: Generate a secure secret)
# Generate with: openssl rand -base64 32
NEXTAUTH_URL="https://fabrk.dev"
NEXTAUTH_SECRET="GENERATE_A_SECURE_64_CHARACTER_SECRET_HERE"

# -----------------------------------------------------------------------------
# AUTHENTICATION - Required for OAuth login
# -----------------------------------------------------------------------------

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID="your-production-google-client-id"
GOOGLE_CLIENT_SECRET="your-production-google-client-secret"

# -----------------------------------------------------------------------------
# PAYMENTS - Required if selling products
# -----------------------------------------------------------------------------

# Stripe (https://dashboard.stripe.com/apikeys)
# Use LIVE keys in production (sk_live_, pk_live_)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Stripe Product Pricing (use lookup keys for flexibility)
NEXT_PUBLIC_STRIPE_PRICE_FABRK="fabrk_purchase"

# Stripe Coupons (optional)
STRIPE_COUPON_EARLY_ADOPTER=""

# Polar.sh (alternative payment processor)
POLAR_ACCESS_TOKEN="polar_..."
POLAR_WEBHOOK_SECRET=""
NEXT_PUBLIC_POLAR_PRODUCT_ID=""

# -----------------------------------------------------------------------------
# EMAIL - Required for transactional emails
# -----------------------------------------------------------------------------

# Resend (https://resend.com/api-keys)
RESEND_API_KEY="re_..."
EMAIL_FROM="support@fabrk.dev"
EMAIL_REPLY_TO="support@fabrk.dev"
EMAIL_WORKER_INTERVAL="5000"

# Cron Jobs
CRON_SECRET="GENERATE_A_SECURE_SECRET_HERE"

# -----------------------------------------------------------------------------
# CACHING & RATE LIMITING - Required for production
# -----------------------------------------------------------------------------

# Upstash Redis (https://console.upstash.com/)
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-production-token"

# -----------------------------------------------------------------------------
# MONITORING & ANALYTICS - Highly recommended
# -----------------------------------------------------------------------------

# Sentry Error Tracking (https://sentry.io/)
NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"
SENTRY_ORG="your-org"
SENTRY_PROJECT="fabrk"
SENTRY_AUTH_TOKEN="your-auth-token"

# PostHog Analytics (https://posthog.com/)
NEXT_PUBLIC_POSTHOG_KEY="phc_..."
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Application Version
NEXT_PUBLIC_APP_VERSION="1.0.0"

# -----------------------------------------------------------------------------
# OPTIONAL - Enable as needed
# -----------------------------------------------------------------------------

# Real-time Features - Pusher (https://pusher.com/)
PUSHER_APP_ID=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# Search - Algolia (https://algolia.com/)
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=""
ALGOLIA_ADMIN_API_KEY=""

# CMS - Sanity (https://sanity.io/)
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_TOKEN=""

# File Storage - Cloudflare R2 (preferred) or AWS S3
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_PUBLIC_URL=""

# AI Features
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# Additional Analytics
NEXT_PUBLIC_GA4_MEASUREMENT_ID=""
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""

# GitHub Integration
GITHUB_ACCESS_TOKEN=""
GITHUB_REPO_OWNER=""
GITHUB_REPO_NAME=""

# Background Jobs
JOB_WORKER_CONCURRENCY="5"
JOB_WORKER_INTERVAL="1000"

# =============================================================================
# DEPLOYMENT CHECKLIST
# =============================================================================
# Before deploying to production:
# [ ] All REQUIRED variables are set
# [ ] Using LIVE Stripe keys (not test)
# [ ] NEXTAUTH_SECRET is unique and secure
# [ ] CRON_SECRET is unique and secure
# [ ] Database SSL mode enabled
# [ ] Redis configured for rate limiting
# [ ] Sentry configured for error tracking
# [ ] Webhooks configured in Stripe/Polar dashboards
# [ ] DNS/SSL configured for custom domain
# =============================================================================
